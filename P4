Create database CUSTOMERS;
USE CUSTOMERS;

-- CREATE CUSTOMER TABLE--
CREATE TABLE CUSTOMERS(
ID INT PRIMARY KEY,
NAME VARCHAR(255),
AGE INT,
ADDRESS VARCHAR(255),
SALARY DECIMAL(10, 2));

