DELIMITER //
CREATE TRIGGER after_insert_salary_difference
AFTER INSERT ON CUSTOMERS
FOR EACH ROW
BEGIN
 SET @my_sal_diff = CONCAT('salary inserted is ', NEW.SALARY);
END;//
DELIMITER ;

-- TO INSERT VALUES AFTER TRIGGER
